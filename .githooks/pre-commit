#!/bin/sh
# POSIX shim → PowerShell implementation.
#
# Git invokes the hook named exactly "pre-commit" via its bundled sh. We cannot
# point a shebang straight at pwsh, because `pwsh -File` rejects any script
# whose name does not end in .ps1 ("...does not have a '.ps1' extension"), and
# the hook file must be named pre-commit. So this shim (which sh runs happily)
# delegates to the sibling pre-commit.ps1.
#
# Both files MUST stay LF — see .gitattributes (.githooks/** text eol=lf). A
# CRLF shebang here resolves to "/bin/sh\r" and fails to spawn.
dir=$(dirname "$0")
pwsh -NoProfile -ExecutionPolicy Bypass -File "$dir/pre-commit.ps1"
exit $?
