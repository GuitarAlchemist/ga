{
  "env": {
    "CLAUDE_CODE_AUTOCOMPACT_PCT_OVERRIDE": "40"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NoProfile -Command \"try { $hookData = $input | ConvertFrom-Json; $f = $hookData.tool_input.file_path; if ($f -and $f -match 'GA\\.Business\\.DSL') { Write-Host 'DSL file changed' } } catch { }\""
          }
        ]
      },
      {
        "matcher": "Edit|Write|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NoProfile -File $CLAUDE_PROJECT_DIR/Scripts/digest-activity-tracker.ps1"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NoProfile -File $CLAUDE_PROJECT_DIR/Scripts/digest-staleness-nudge.ps1"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NoProfile -File $CLAUDE_PROJECT_DIR/Scripts/precompact-digest.ps1"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NoProfile -Command \"Write-Host ''; Write-Host 'Guitar Alchemist Session' -ForegroundColor Cyan; Write-Host ('  Branch: ' + (git branch --show-current)) -ForegroundColor Gray; try { $vite = (Invoke-WebRequest -Uri 'http://localhost:5176' -TimeoutSec 3 -UseBasicParsing -ErrorAction Stop).StatusCode; Write-Host ('  Vite: OK (' + $vite + ')') -ForegroundColor Green } catch { Write-Host '  Vite: DOWN (port 5176) - run: pwsh Scripts/start-dev.ps1' -ForegroundColor Red }; try { $api = (Invoke-WebRequest -Uri 'http://localhost:5232/health' -TimeoutSec 3 -UseBasicParsing -ErrorAction Stop).Content; Write-Host ('  API: ' + $api) -ForegroundColor $(if($api -eq 'Healthy'){'Green'}else{'Yellow'}) } catch { Write-Host '  API: DOWN (port 5232)' -ForegroundColor Red }; Write-Host ''\""
          }
        ]
      },
      {
        "matcher": "compact|resume",
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NoProfile -File $CLAUDE_PROJECT_DIR/Scripts/sessionstart-digest.ps1"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NoProfile -File $CLAUDE_PROJECT_DIR/Scripts/session-pr-check.ps1"
          },
          {
            "type": "command",
            "command": "pwsh -NoProfile -File $CLAUDE_PROJECT_DIR/Scripts/digest-stop-finalize.ps1"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "context7@claude-plugins-official": true,
    "coding-tutor@compound-engineering-plugin": true,
    "compound-engineering@compound-engineering-plugin": true,
    "ga@guitar-alchemist": true,
    "frontend-design@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "ralph-loop@claude-plugins-official": true,
    "chrome-devtools-mcp@claude-plugins-official": true,
    "greptile@claude-plugins-official": true,
    "huggingface-skills@claude-plugins-official": true,
    "microsoft-docs@claude-plugins-official": true,
    "atomic-agents@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "guitar-alchemist": {
      "source": {
        "source": "directory",
        "path": "."
      }
    }
  }
}
