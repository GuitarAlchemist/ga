    { "id": "in-1",  "prompt": "interval between C and G",                              "expectedIntentId": "skill.interval",           "tags": ["common"] },
    { "id": "in-2",  "prompt": "what's a perfect fifth",                                "expectedIntentId": "skill.interval",           "tags": ["common"] },
    { "id": "fs-1",  "prompt": "fret span between fret 3 and fret 7",                   "expectedIntentId": "skill.fretspan",           "tags": ["common"] },
    { "id": "fs-2",  "prompt": "how many frets between 5 and 12",                       "expectedIntentId": "skill.fretspan",           "tags": ["common"] },
