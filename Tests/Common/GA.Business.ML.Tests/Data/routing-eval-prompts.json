{
  "$schema": "../Eval/routing-eval-prompts.schema.json",
  "version": "0.1",
  "description": "Labeled prompt set for SemanticIntentRouter evaluation. Each entry pairs a user-style prompt with the intent ID it SHOULD route to. The harness routes the prompt through SemanticIntentRouter (with real embeddings + DefaultRoutingHintProvider) and compares the chosen intent against `expectedIntentId`. Used to establish baselines and detect routing regressions when changes ship.",
  "lastUpdated": "2026-05-11",
  "intentIdsCovered": [
    "skill.chordinfo",
    "skill.scaleinfo",
    "skill.modes",
    "skill.interval",
    "skill.fretspan",
    "skill.chordsubstitution",
    "skill.beginnerchords",
    "skill.progressionmood",
    "skill.circleoffifths",
    "skill.practiceroutine",
    "skill.genreessentials",
    "skill.whatcanyoudo",
    "skill.transpose",
    "skill.commontones",
    "skill.diatonicchords",
    "skill.keyidentification",
    "skill.progressioncompletion"
  ],
  "prompts": [
