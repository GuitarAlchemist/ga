{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "AI": {
    "ChatProvider": "ollama",
    "EmbeddingProvider": "ollama",
    "Embedding": {
      "routing": {
        "Model": "bge-large"
      }
    },
    "Routing": {
      "MinConfidence": 0.64
    }
  },
  "Ollama": {
    "BaseUrl": "http://localhost:11434",
    "Endpoint": "http://localhost:11434",
    "ChatModel": "llama3.2:3b",
    "EmbeddingModel": "nomic-embed-text"
  },
  "DockerModelRunner": {
    "BaseUrl": "http://localhost:12434/v1"
  },
  "VectorStore": {
    "Backend": "file",
    "File": {
      "Path": "state/chatbot/voicing_index.jsonl"
    }
  },
  "VoicingSearch": {
    "MinPlayedNotes": 2,
    "MaxVoicingsToIndex": 4000,
    "NoteCountFilter": "All"
  },
  "Chatbot": {
    "Mode": "full",
    "Model": "llama3.2:3b",
    "HistoryLimit": 12,
    "StreamTimeoutSeconds": 180,
    "PathBase": "/chatbot",
    "Memory": {
      "InjectContext": false,
      "PersistResponses": true
    }
  },
  "IX": {
    "Source": "ix-compatible",
    "Revision": "7b02a56",
    "External": {
      "Enabled": true,
      "TimeoutSeconds": 10,
      "Arguments": [
        "algebra",
        "--source",
        "ix",
        "--revision",
        "7b02a56"
      ]
    }
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173",
      "http://localhost:5174",
      "http://localhost:5176",
      "http://localhost:5177"
    ]
  }
}
