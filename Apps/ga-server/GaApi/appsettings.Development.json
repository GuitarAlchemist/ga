{
  // ─── Dev Environment Contract ─────────────────────────────────────────────
  // Aspire orchestrates: MongoDB (Docker), Redis, all microservices
  // GaApi runs: dotnet run (or via Aspire) — never from a Docker image
  // LLM backend: Ollama at localhost:11434 (native API, always local)
  // MongoDB: Aspire injects ConnectionStrings__guitar-alchemist automatically.
  //          The MongoDB section below is only the fallback for dotnet run
  //          without Aspire (e.g. rapid iteration). When Aspire is running,
  //          PostConfigure in InfrastructureServiceExtensions overrides it.
  // ─────────────────────────────────────────────────────────────────────────
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "GA.Business.ML": "Debug"
    }
  },
  "AI": {
    "ChatProvider": "ollama",
    "EmbeddingProvider": "ollama"
  },
  "Anthropic": {
    "Model": "claude-haiku-4-5-20251001"
  },
  "VectorStore": {
    "Backend": "memory"
  },
  "VoicingSearch": {
    "EnableIndexing": true,
    "LazyLoading": true
  },
  "Chatbot": {
    "Model": "gemma4:26b-a4b-it-q4_K_M"
  },
  "Ollama": {
    "BaseUrl": "http://localhost:11434",
    "Endpoint": "http://localhost:11434",
    "ChatModel": "gemma4:26b-a4b-it-q4_K_M",
    "EmbeddingModel": "nomic-embed-text:latest"
  },
  "DockerModelRunner": {
    "BaseUrl": "http://localhost:12434/v1",
    "ChatModel": "docker.io/ai/llama3.2:latest",
    "EmbeddingModel": "docker.io/ai/mxbai-embed-large:latest"
  }
}
