{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "MusicalKnowledge": "Data Source=musical-knowledge.db"
  },
  "AllowedHosts": "*",
  "OpenAI": {
    // ApiKey must come from env var OPENAI__APIKEY or dotnet user-secrets — never committed here
    "Model": "text-embedding-3-small"
  },
  "VoicingSearch": {
    "MaxVoicingsToIndex": 2147483647,
    "MinPlayedNotes": 2,
    "NoteCountFilter": "All",
    "EnableIndexing": true,
    "LazyLoading": false
  },
  "VectorSearch": {
    "PreferredStrategies": [
      "CUDA",
      "InMemory",
      "MongoDB"
    ],
    "EnableAutoSwitching": false,
    "AutoSwitchThreshold": 20.0,
    "PreloadStrategies": false,
    "MaxMemoryUsageMB": 2048
  },
  "Graphiti": {
    "BaseUrl": "http://localhost:8000",
    "Timeout": "00:00:30",
    "MaxRetries": 3
  },
  "Caching": {
    "Regular": {
      "ExpirationMinutes": 15,
      "SizeLimit": 1000
    },
    "Semantic": {
      "ExpirationMinutes": 5,
      "SizeLimit": 100
    }
  },
  "Chatbot": {
    "EnableSemanticSearch": true,
    "StreamTimeoutSeconds": 60,
    "HistoryLimit": 12,
    "SemanticSearchLimit": 5,
    "Model": "llama3.2:3b",
    "SemanticContextDocuments": 3
  },
  "GuitarAgents": {
    "Temperature": 0.6,
    "TopP": 0.9,
    "MaxOutputTokens": 600,
    "TimeoutSeconds": 45,
    "IncludeRawOutput": true,
    "EnableQualityPass": true
  },
  "VoxtralTts": {
    // ApiKey must come from env var VOXTRAL_TTS__APIKEY or dotnet user-secrets — never committed here
    "BaseUrl": "https://api.mistral.ai",
    "Model": "voxtral-mini-tts-2603",
    "Voice": "e3596645-b1af-469e-b857-f18ddedc7652",
    "ResponseFormat": "mp3",
    "MaxTextLength": 5000
  },
  "KokoroTts": {
    "BaseUrl": "http://localhost:8880",
    "DefaultVoice": "af_bella",
    "Model": "kokoro",
    "ResponseFormat": "mp3",
    "TimeoutSeconds": 10,
    "MaxTextLength": 5000
  },
  "TarsMcp": {
    "BaseUrl": "http://localhost:9001",
    "Timeout": "00:00:10",
    "EnableGpuMonitoring": true,
    "EnableSystemMonitoring": true
  },
  "ReverseProxy": {
    "Routes": {
      "music-theory-route": {
        "ClusterId": "music-theory-cluster",
        "Match": {
          "Path": "/api/music-theory/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "music-theory-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://music-theory-service"
          }
        }
      }
    }
  }
}