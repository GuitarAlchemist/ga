@page "/fret-span-explorer"
@using GA.Domain.Core.Instruments.Fretboard.Analysis
@using GA.Domain.Core.Instruments.Primitives
@using GA.Domain.Services.Fretboard.Analysis

<PageTitle>Fret Span Explorer</PageTitle>

<MudText Typo="Typo.h3" GutterBottom="true">Fret Span Explorer</MudText>
<MudText Class="mb-4">Analyze all possible chord positions within 5-fret spans</MudText>

<MudPaper Class="pa-4 mb-4">
    <MudGrid>
        <MudItem xs="12" md="4">
            <MudNumericField @bind-Value="_startFret" Label="Start Fret" Min="0" Max="19"/>
        </MudItem>
        <MudItem xs="12" md="4">
            <MudNumericField @bind-Value="_maxChords" Label="Max Chords to Display" Min="10" Max="1000"/>
        </MudItem>
        <MudItem xs="12" md="4">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="AnalyzeFretSpan" FullWidth="true"
                       Class="mt-3">
                Analyze
            </MudButton>
        </MudItem>
    </MudGrid>
</MudPaper>

@if (_isLoading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="my-4"/>
}

@if (_chordResults != null && _chordResults.Any())
{
    <MudText Typo="Typo.h5" Class="mb-3">
        Found @_chordResults.Count chords in frets @_startFret - @(_startFret + 5)
    </MudText>

    <MudTable Items="_chordResults" Hover="true" Breakpoint="Breakpoint.Sm" Dense="true"
              Filter="new Func<FiveFretSpanChord, bool>(FilterFunc)">
        <ToolBarContent>
            <MudText Typo="Typo.h6">Chord Positions</MudText>
            <MudSpacer/>
            <MudTextField @bind-Value="_searchString" Placeholder="Search" Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium"
                          Class="mt-0"></MudTextField>
        </ToolBarContent>
        <HeaderContent>
            <MudTh>Chord Name</MudTh>
            <MudTh>Fret Span</MudTh>
            <MudTh>Pattern</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Chord Name">
                <MudText Typo="Typo.body2"><strong>@context.ChordName</strong></MudText>
            </MudTd>
            <MudTd DataLabel="Fret Span">@context.LowestFret - @context.HighestFret</MudTd>
            <MudTd DataLabel="Pattern">@context.Invariant.PatternId.ToPatternString()</MudTd>
        </RowTemplate>
        <PagerContent>
            <MudTablePager/>
        </PagerContent>
    </MudTable>
}
else if (!_isLoading && _hasAnalyzed)
{
    <MudAlert Severity="Severity.Info">No chords found for the selected fret span.</MudAlert>
}

@code {
    private int _startFret;
    private int _maxChords = 100;
    private bool _isLoading;
    private bool _hasAnalyzed;
    private string _searchString = "";
    private List<FiveFretSpanChord>? _chordResults;

    private async Task AnalyzeFretSpan()
    {
        _isLoading = true;
        _hasAnalyzed = true;
        _chordResults = null;
        StateHasChanged();

        try
        {
            var fretboard = Fretboard.Default;
            var allChords = FretboardChordAnalyzer.GenerateAllFiveFretSpanChords(fretboard, _startFret + 5)
                .Where(c => c.LowestFret >= _startFret && c.HighestFret <= _startFret + 5)
                .Take(_maxChords)
                .ToList();

            _chordResults = allChords;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error analyzing fret span: {ex.Message}");
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }

        await Task.CompletedTask;
    }

    private bool FilterFunc(FiveFretSpanChord chord)
    {
        if (string.IsNullOrWhiteSpace(_searchString))
            return true;

        return chord.ChordName.Contains(_searchString, StringComparison.OrdinalIgnoreCase);
    }
}
