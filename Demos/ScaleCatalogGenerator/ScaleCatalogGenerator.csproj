<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <OutputType>Exe</OutputType>
        <TargetFramework>net10.0</TargetFramework>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
        <RootNamespace>GA.Demos.ScaleCatalogGenerator</RootNamespace>
        <AssemblyName>ScaleCatalogGenerator</AssemblyName>
        <TreatWarningsAsErrors>false</TreatWarningsAsErrors>
    </PropertyGroup>

    <ItemGroup>
        <!--
            Reference GA.Domain.Core for ForteCatalog / PitchClassSet lookup.
            All other properties are computed directly from the 12-bit bitmask,
            so this reference is strictly for Forte-number consistency across GA.
        -->
        <ProjectReference Include="..\..\Common\GA.Domain.Core\GA.Domain.Core.csproj" />
    </ItemGroup>

    <ItemGroup>
        <PackageReference Include="YamlDotNet" Version="16.2.1" />
    </ItemGroup>

</Project>
