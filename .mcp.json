{
  "mcpServers": {
    "ga-dsl": {
      "type": "stdio",
      "command": "dotnet",
      "args": [
        "run",
        "--project",
        "GaMcpServer/GaMcpServer.csproj",
        "--no-build",
        "--"
      ]
    },
    "ix": {
      "command": "cargo",
      "args": ["run", "--release", "-p", "ix-agent"],
      "cwd": "C:/Users/spare/source/repos/ix"
    },
    "meshy-ai": {
      "type": "stdio",
      "command": "node",
      "args": ["mcp-servers/meshy-ai/dist/index.js"],
      "env": {
        "MESHY_API_KEY": "${MESHY_API_KEY}"
      }
    },
    "demerzel": {
      "type": "stdio",
      "command": "dotnet",
      "args": ["run", "--project", "Apps/demerzel-bridge/DemerzelBridge/DemerzelBridge.csproj", "--no-build"],
      "env": {
        "DEMERZEL_API_KEY": "${DEMERZEL_API_KEY}",
        "DEMERZEL_URL": "http://localhost:8200"
      }
    }
  }
}
