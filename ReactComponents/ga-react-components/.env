# API Configuration — leave empty to auto-detect from page origin
# Set explicitly only for local dev with non-standard ports
# VITE_API_BASE_URL=http://localhost:5232

# LLM Provider flags — mark providers as configured for the LLM Status panel.
# These are boolean flags only (no secrets!) — actual API keys live in system env vars.
VITE_OPENAI_CONFIGURED=1
VITE_GEMINI_CONFIGURED=1
VITE_CODEX_CONFIGURED=1
# VITE_VOXTRAL_CONFIGURED=1  # Uncomment when MISTRAL_API_KEY is set
