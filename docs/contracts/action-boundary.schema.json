{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/GuitarAlchemist/ga/docs/contracts/action-boundary.schema.json",
  "title": "Action boundary (Jarvis Track J3)",
  "description": "Single machine-readable statement of what an autonomous actor may touch, what halts it, and which cost lane it runs on. GENERATED by Scripts/action-boundary-aggregate.py from the canonical fragments (agent-blackbox.policy.json, ga.loop-policy.json, Scripts/Governance.psm1, the cost doctrine) — never hand-edited. Contract: 2026-07-02-action-boundary.contract.md (v0.1 DRAFT).",
  "type": "object",
  "required": [
    "schema",
    "generated_at",
    "generated_by",
    "repo",
    "sources",
    "capabilities",
    "halt",
    "cost_lanes",
    "one_way_doors"
  ],
  "properties": {
    "schema": { "const": "action-boundary-v0.1.0" },
    "generated_at": { "type": "string", "format": "date-time" },
    "generated_by": { "type": "string" },
    "repo": { "type": "string" },
    "sources": {
      "type": "object",
      "description": "Repo-relative paths of the canonical fragments this instance projects. If an entry here and the projection disagree, the fragment wins.",
      "required": ["risk_policy", "loop_policy", "halt_semantics", "cost_doctrine"],
      "additionalProperties": { "type": "string" }
    },
    "capabilities": {
      "type": "object",
      "required": ["allow_edit", "protected_paths", "blocked_paths", "one_way_door_paths"],
      "properties": {
        "allow_edit": { "$ref": "#/$defs/pathGlobList" },
        "protected_paths": { "$ref": "#/$defs/pathGlobList" },
        "blocked_paths": { "$ref": "#/$defs/pathGlobList" },
        "one_way_door_paths": { "$ref": "#/$defs/pathGlobList" }
      },
      "additionalProperties": false
    },
    "risk_thresholds": {
      "type": "object",
      "properties": {
        "pass": { "type": "number", "minimum": 0, "maximum": 1 },
        "warn": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "required_evidence": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "halt": {
      "type": "object",
      "required": ["halt_all_marker", "local_killswitch", "stop_marker", "semantics"],
      "properties": {
        "halt_all_marker": { "type": "string", "minLength": 1 },
        "local_killswitch": { "type": "string", "minLength": 1 },
        "stop_marker": { "type": "string", "minLength": 1 },
        "semantics": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "cost_lanes": {
      "type": "object",
      "required": ["subscription_only", "api_fallback_allowed", "rule"],
      "properties": {
        "subscription_only": { "type": "array", "items": { "type": "string" } },
        "api_fallback_allowed": { "type": "array", "items": { "type": "string" } },
        "rule": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "one_way_doors": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "audit": {
      "type": "object",
      "properties": {
        "expectation": { "type": "string" },
        "status": { "type": "string" }
      }
    }
  },
  "$defs": {
    "pathGlobList": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    }
  }
}
