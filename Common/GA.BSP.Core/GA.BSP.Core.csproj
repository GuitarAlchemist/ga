<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <NoWarn>$(NoWarn);IDE0065</NoWarn>
  </PropertyGroup>

  <!-- Exclude files that reference unimplemented modular restructuring namespaces -->
  <!-- These belong in GA.Business.Core.Orchestration per docs/MODULAR_RESTRUCTURING_PLAN.md -->
  <ItemGroup>
    <Compile Remove="BSP/IntelligentBSPGenerator.cs" />
    <Compile Remove="BSP/IntelligentBSPGenerator.Optimized.cs" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" Version="9.0.10"/>
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="../GA.Core/GA.Core.csproj"/>
    <ProjectReference Include="../GA.Domain.Core/GA.Domain.Core.csproj" />
    <ProjectReference Include="../GA.Domain.Services/GA.Domain.Services.csproj" />
  </ItemGroup>

</Project>

