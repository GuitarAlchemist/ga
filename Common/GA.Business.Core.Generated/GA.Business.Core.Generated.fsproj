<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFramework>net10.0</TargetFramework>
        <GenerateDocumentationFile>true</GenerateDocumentationFile>
    </PropertyGroup>

    <!-- Generated .g.fs files are produced by the EbnfGeneratorTask in GA.Business.DSL.SourceGen. -->
    <ItemGroup>
        <Compile Include="Generated/ChordSymbol.g.fs" Condition="Exists('Generated/ChordSymbol.g.fs')" />
        <Compile Include="Generated/ChordProgression.g.fs" Condition="Exists('Generated/ChordProgression.g.fs')" />
        <Compile Include="Generated/ScaleTransformation.g.fs" Condition="Exists('Generated/ScaleTransformation.g.fs')" />
        <Compile Include="Generated/FretboardNavigation.g.fs" Condition="Exists('Generated/FretboardNavigation.g.fs')" />
        <Compile Include="Generated/GrothendieckOperations.g.fs" Condition="Exists('Generated/GrothendieckOperations.g.fs')" />
        <Compile Include="Generated/PracticeRoutine.g.fs" Condition="Exists('Generated/PracticeRoutine.g.fs')" />
        <Compile Include="Generated/VexTab.g.fs" Condition="Exists('Generated/VexTab.g.fs')" />
        <Compile Include="Generated/AsciiTab.g.fs" Condition="Exists('Generated/AsciiTab.g.fs')" />
        <Compile Include="Generated/Midi.g.fs" Condition="Exists('Generated/Midi.g.fs')" />
    </ItemGroup>

    <ItemGroup>
        <PackageReference Include="FParsec" Version="1.1.1"/>
    </ItemGroup>

</Project>
