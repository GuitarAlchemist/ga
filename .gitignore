# =============================================================================
/Experiments/Vite/node_modules/
/Experiments/Vite/package-lock.json
/Experiments/React/.idea/
/Experiments/React/node_modules/

# Ignore temp files
*.txt
!README.txt

# Ignore cache indexes
Apps/ga-server/GaApi/cache/
jetbrains-plugin/.gradle/

# Claude Code local settings and working directories (not shared)
.claude/settings.local.json
.claude/worktrees/

# AI chat exports (ChatGPT, Gemini, etc. — personal notes, not repo artifacts)
ChatGPT-*.md
Gemini-*.md

# =============================================================================
# Agent skills and generated content
# =============================================================================
# Codex/Gemini agent skills (generated per-machine, not shared)
.agent/

# GA local settings and plugins
.ga/

# ML model binaries (too large for git, use LFS or artifact store)
**/models/*.onnx
**/models/*.bin
**/models/*.pt
**/models/*.pkl

# Debug/scratch files
dumper/
dumper.out
cclsp.json
tab.json
test_tab.json

# Completed code review todos (ephemeral tracking)
todos/

# Blue/Green deployment state files
.slot-target
.slot-state.json
.slot-lock

# OPTIC-K generated index (build artifact, ~660MB)
**/state/voicings/optick.index

# Baseline diagnostic artifacts (regenerable)
state/baseline/embedding-clusters-*.json
state/baseline-phaseE/embedding-clusters-*.json

# Quality-snapshot by-products that are too large for git (the trend tool
# only reads the summary JSONs; cluster-label dumps stay local / regenerable)
state/quality/**/embedding-clusters-*.json

# Phase 3 DSL-eval soak: dated raw results are local artefacts — only
# state/quality/dsl-eval/prompts.json and state/quality/dsl-eval/latest-*
# (when the runner produces them) belong in git. PR #151 review arch-F8
# flagged committing the dated files as repo bloat that hides movement
# when weekly soaks start.
state/quality/dsl-eval/[0-9]*-soak-results.json

# Golden trace snapshots from Scripts/record-golden-traces.ps1.
# Per-run captures (different traceId/elapsedMs each time); not a stable
# baseline. Re-record locally when needed. Dominator analysis runs offline
# against whatever's currently on disk.
state/quality/chatbot-qa/golden-traces/**/run-*.json
state/quality/chatbot-qa/golden-traces/**/_canonical.json
# Note: _signature.json IS tracked — pruned to (name, status, agent.id)
# per step, stable across runs, used as a CI test fixture by
# PromptCorpusTests + CanonicalSignatureChecker.

# Chatbot claim traces — per-day JSONL, regenerable from MCP tool calls
state/claims/
state/chatbot/

# Per-PR chatbot review captures (octo-code-reviewer / multi-LLM panel
# outputs). Each file is the response for one PR review run; regenerable on
# demand from `/octo:review <PR>`. Sibling to state/chatbot/.
state/chatbot-reviews/

# Memory curator run outputs — dated subfolders of per-run JSON for the
# offline summarization passes that mine ChatTranscriptStore for durable
# memory. Regenerable from `Scripts/run-memory-curator.ps1`.
state/quality/memory-curator/

# Voicing-search + GaChatbot.Api telemetry — per-day JSONL distributions
# (state/telemetry/voicing-search/YYYY-MM-DD.jsonl) and api-process stdout/
# stderr captures. Both are runtime artifacts: telemetry is what the next
# baseline sweep reads, stdout/stderr is debugging-only.
state/telemetry/

# AI-surface handoff notes — working memory between Antigravity native, Claude
# Code, and remote agents. Notes ARE ignored; the README explaining the
# protocol is tracked.
state/handoffs/*
!state/handoffs/README.md

# Session digests — per-session cursor state captured by the /digest skill
# and the PreCompact hook fallback. The README explaining the layout is
# tracked; the digest contents (which may include in-flight model context)
# are gitignored.
state/digests/*
!state/digests/README.md

# Thin chatbot host deployment files stay local/private
Apps/GaChatbot.Api/appsettings.Production.json
Apps/GaChatbot.Api/.env*
Apps/GaChatbot.Api/railway.toml
Apps/GaChatbot.Api/vercel.json
Apps/GaChatbot.Api/.vercel/
Apps/GaChatbot.Api/.azure/

# Local build artifact packages (regenerable)
.artifacts/

# Codex CLI experiment scratch directories
.codex-temp-slnx/
.codex-temp-solution/
.codex_tmp_probe.csx

# .NET local toolchain sentinels (per-machine state)
.dotnet/

# Claude Code session scratch (validation prompts/results live here)
.claude/octopus-validation/

# Playwright artifacts — regenerated on every test run
Apps/ga-client/test-results/
Apps/ga-client/playwright-report/

# MCP Playwright snapshot traces — auto-generated by the chrome-devtools /
# playwright MCP server on every browser_snapshot. Each file is a YAML dump
# of a page accessibility tree at a timestamp; they accumulate hundreds-fast
# during a single agent session and have zero replay value outside that
# session. Pre-existing local clones already have ~60+ of these untracked.
.playwright-mcp/

# Local SAE training artifacts (per-developer-machine validation runs).
# Real Phase 1 agent runs land at state/quality/optick-sae/<date>/ (no -local suffix).
state/quality/optick-sae/*-local/

# Claude Octopus per-machine session state.
.claude-octopus/

# Subset solution experiments at repo root — Codex / agent scratch when
# restoring a partial graph. Block everything except the canonical one.
/*.slnx
!/AllProjects.slnx

# Supervised-loop ephemeral evidence — regenerated by Scripts/dev-process-overseer.ps1
# and the supervised-loop skill. Both are produced per-run; only the
# baseline.json under state/quality/* is tracked.
state/governance/dev-process-overseer.json
state/governance/supervised-loop-cycle.json
.STOP
